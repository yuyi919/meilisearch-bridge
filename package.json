{
  "name": "meilisearch-bridge",
  "version": "0.0.0",
  "private": true,
  "description": "A pnpm monorepo that wraps the Meilisearch search engine (vendored as a subtree) as a Node.js addon via napi-rs, and exposes a SDK-style API matching the official meilisearch-js interface.",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @meilisearch-bridge/core build",
    "build:api": "pnpm --filter @meilisearch-bridge/api build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" \"!native/**\" \"!**/node_modules/**\" \"!**/dist/**\"",
    "sync:upstream": "git subtree pull --prefix=native/meilisearch meilisearch-upstream main --squash"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}