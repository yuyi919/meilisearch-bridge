{
  "name": "@yuyi919/meilisearch-bridge-core",
  "version": "0.0.1",
  "description": "napi-rs native addon wrapping Meilisearch's milli search engine",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "meilisearch-bridge-core",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ],
    "packageName": "@yuyi919/meilisearch-bridge-core"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "meilisearch-bridge-core.linux-x64-gnu.node",
    "meilisearch-bridge-core.linux-x64-musl.node",
    "meilisearch-bridge-core.linux-arm64-gnu.node",
    "meilisearch-bridge-core.darwin-x64.node",
    "meilisearch-bridge-core.darwin-arm64.node",
    "meilisearch-bridge-core.win32-x64-msvc.node"
  ],
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "create-npm-dirs": "napi create-npm-dirs",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "node --test __test__/*.test.cjs",
    "version": "napi version",
    "clean": "rm -rf target *.node"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.2"
  }
}
